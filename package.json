{
  "name": "magpie-weaver",
  "description": "The Magpie Weaver root package",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.15.1",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.15.1",
      "onFail": "download"
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "gate-check": "pnpm exec gate-checks"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@magpieweaver/gate-checks": "workspace:*",
    "eslint": "^10.7.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.65.0",
    "@types/node": "^26.1.1",
    "vitest": "4.1.10"
  }
}
